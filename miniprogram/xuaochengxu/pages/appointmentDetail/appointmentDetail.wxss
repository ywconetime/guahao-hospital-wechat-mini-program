/* appointmentDetail.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 顶部标题 */
.header {
  background: #ffffff;
  padding: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 状态条 */
.status-bar {
  background: var(--primary-color);
  color: white;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

/* 通用部分样式 */
.section {
  background-color: white;
  margin-top: 20rpx;
  padding: 20rpx 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 4rpx solid var(--primary-color);
  padding-left: 15rpx;
}

/* 信息项 */
.info-item {
  display: flex;
  margin-bottom: 15rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #666;
  width: 150rpx;
  font-weight: 500;
}

.value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  font-weight: 500;
}

/* 取消预约按钮 */
.cancel-btn {
  margin: 40rpx 30rpx;
  background: #ffffff;
  color: #666;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  width: calc(100% - 60rpx);
  box-sizing: border-box;
}

.cancel-btn:active {
  background: #f5f5f5;
}