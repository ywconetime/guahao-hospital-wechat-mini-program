<!--webview.wxml-->
<!-- 加载动画（webview加载完成前显示） -->
<view wx:if="{{!webviewLoaded && url}}" class="webview-loading">
  <view class="loading-spinner"></view>
  <text class="loading-text">正在加载中...</text>
</view>

<!-- webview内容 -->
<view class="webview-container" wx:if="{{url}}">
  <web-view src="{{url}}" bindload="webviewLoadSuccess"></web-view>
</view>