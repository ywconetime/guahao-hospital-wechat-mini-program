/* appointmentForm.wxss */
.container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 顶部标题 */
.header {
  background: #ffffff;
  padding: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 通用部分样式 */
.section {
  background-color: white;
  padding: 30rpx;
  margin-bottom: 12rpx;
  position: relative;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #333;
  display: flex;
  align-items: center;
}

/* 信息项 */
.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.info-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #666;
  width: 180rpx;
  font-weight: 500;
}

.value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  font-weight: 500;
}

/* 时间段选择 */
.time-slot-options {
  flex: 1;
  display: flex;
  gap: 40rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: #333;
  cursor: pointer;
}

.radio-label:hover {
  color: #007AFF;
}

/* 表单项目 */
.form-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 24rpx;
  width: 100%;
}

.form-item label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  font-weight: 500;
  width: 100%;
}

.phone-input-container {
  width: 100%;
  position: relative;
}

.input {
  width: 100%;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 24rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
  box-sizing: border-box;
  background-color: #f9f9f9;
  height: 80rpx;
}

.get-phone-btn {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #007AFF;
  color: white;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
  border: none;
  min-width: 160rpx;
  text-align: center;
}

.phone-button-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: transparent;
  color: transparent;
  border: none;
  padding: 0;
  margin: 0;
  z-index: 10;
  opacity: 0;
  cursor: pointer;
}

.input:focus {
  border-color: #007AFF;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.1);
  background-color: white;
}

.input::placeholder {
  color: #999;
  font-size: 26rpx;
}

/* 性别选择 */
.gender-options {
  display: flex;
  gap: 40rpx;
  width: 100%;
  margin-top: 10rpx;
}

/* 病情症状描述 */
.textarea {
  width: 100%;
  height: 250rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 24rpx;
  font-size: 28rpx;
  resize: none;
  transition: all 0.3s ease;
  box-sizing: border-box;
  background-color: #f9f9f9;
  line-height: 1.5;
}

.textarea:focus {
  border-color: #007AFF;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.1);
  background-color: white;
}

.textarea::placeholder {
  color: #999;
  font-size: 26rpx;
}

/* 提交按钮 */
.submit-btn {
  margin: 30rpx 0;
  background: #007AFF;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 8rpx;
  border: none;
  width: 100%;
  box-sizing: border-box;
}

.submit-btn:active {
  background: #0056b3;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 16rpx;
  }
  
  .section {
    padding: 24rpx;
  }
  
  .section-title {
    font-size: 32rpx;
  }
  
  .input,
  .textarea {
    padding: 18rpx;
    font-size: 26rpx;
  }
  
  .submit-btn {
    padding: 22rpx;
    font-size: 30rpx;
  }
}

/* 自定义单选按钮样式 */
radio {
  transform: scale(0.9);
}

radio[checked] {
  color: #007AFF;
}

/* 选择器样式 */
.picker-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  border: 1rpx solid #e0e0e0;
  transition: all 0.3s ease;
}

.picker-container:hover {
  border-color: #007AFF;
  background-color: #f0f8ff;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 10rpx;
  transition: transform 0.3s ease;
}

.picker-container:hover .picker-arrow {
  transform: rotate(180deg);
  color: #007AFF;
}
