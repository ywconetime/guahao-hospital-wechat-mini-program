/* personalInfo.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 30rpx;
}

.header {
  background-color: #007AFF;
  color: white;
  padding: 20rpx;
  text-align: center;
  position: relative;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
}

.info-section {
  background-color: white;
  margin-top: 20rpx;
  padding: 0 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.avatar-container {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.avatar-btn {
  background-color: #007AFF;
  color: white;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: none;
}

.info-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
}

.info-picker {
  flex: 1;
  text-align: right;
}

.bind-btn {
  background-color: #007AFF;
  color: white;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: none;
  margin-left: 20rpx;
}

.save-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 30rpx;
  font-weight: bold;
  margin-top: 40rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  border: none;
}

.save-btn:hover {
  opacity: 0.9;
}