<!-- personalInfo.wxml -->
<view class="container">
  <view class="header" style="background-color: {{themeColor}};">
    <text class="title">个人信息</text>
  </view>
  
  <view class="info-section">
    <view class="info-item">
      <text class="info-label">头像</text>
      <view class="avatar-container">
        <image src="{{userInfo.avatarUrl || '/images/no-results.png'}}" mode="aspectFill" class="avatar" />
        <button class="avatar-btn" style="background-color: {{themeColor}};" bindtap="chooseAvatar">更换头像</button>
      </view>
    </view>
    
    <view class="info-item">
      <text class="info-label">昵称</text>
      <input type="text" class="info-input" value="{{userInfo.nickName || ''}}" bindinput="onNickNameChange" placeholder="请输入昵称" />
    </view>
    
    <view class="info-item">
      <text class="info-label">手机号</text>
      <text class="info-value">{{userInfo.phone || '未绑定'}}</text>
      <button wx:if="!userInfo.phone" open-type="getPhoneNumber" bindgetphonenumber="bindPhoneNumber" class="bind-btn" style="background-color: {{themeColor}};">绑定手机号</button>
    </view>
    
    <view class="info-item">
      <text class="info-label">性别</text>
      <picker class="info-picker" range="{{genderArray}}" value="{{genderIndex}}" bindchange="onGenderChange">
        <text class="info-value">{{genderArray[genderIndex]}}</text>
      </picker>
    </view>
    
    <view class="info-item">
      <text class="info-label">生日</text>
      <input type="date" class="info-input" value="{{userInfo.birthday || ''}}" bindinput="onBirthdayChange" />
    </view>
  </view>
  
  <button class="save-btn" style="background-color: {{themeColor}};" bindtap="savePersonalInfo">保存修改</button>
</view>