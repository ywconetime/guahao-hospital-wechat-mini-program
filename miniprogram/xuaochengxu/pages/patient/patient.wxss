/* patient.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.header {
  background-color: var(--primary-color);
  color: white;
  padding: 40rpx 30rpx;
  text-align: center;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
}

.patient-item {
  background-color: white;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.patient-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.patient-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 30rpx;
}

.patient-gender {
  font-size: 28rpx;
  color: #666;
  margin-right: 30rpx;
}

.patient-age {
  font-size: 28rpx;
  color: #666;
}

.patient-phone {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.patient-actions {
  display: flex;
  justify-content: flex-end;
}

.edit-btn {
  background-color: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 5rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
  margin-right: 20rpx;
}

.delete-btn {
  background-color: #ff4d4f;
  color: white;
  border: none;
  border-radius: 5rpx;
  padding: 10rpx 30rpx;
  font-size: 26rpx;
}

.add-btn {
  position: fixed;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: var(--primary-color);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.4);
}
