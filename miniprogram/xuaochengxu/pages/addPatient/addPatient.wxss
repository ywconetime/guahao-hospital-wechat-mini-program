.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.input {
  font-size: 30rpx;
  padding: 20rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
}

.gender-group {
  display: flex;
  gap: 30rpx;
}

.gender-option {
  padding: 20rpx 40rpx;
  background-color: #f8f8f8;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.submit-btn {
  margin-top: 40rpx;
  color: #fff;
  border-radius: 10rpx;
  height: 88rpx;
  font-size: 32rpx;
  border: none;
  padding: 0;
}