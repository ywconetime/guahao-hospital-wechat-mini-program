/* doctorDetail.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 医生基本信息 */
.doctor-info {
  display: flex;
  padding: 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.doctor-avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
}

.doctor-basic {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.doctor-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.doctor-title {
  font-size: 28rpx;
  color: #666;
}

.doctor-position {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

/* 医生介绍 */
.section {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #000000;
  margin-bottom: 10rpx;
}

.doctor-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: #666;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item.active {
  color: #007AFF;
  border-bottom: 4rpx solid #007AFF;
}

/* 排班信息 */
.schedule-section {
  background-color: #fff;
  padding: 20rpx;
}

.schedule-group {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fafafa 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
}

.schedule-date-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx dashed #e8e8e8;
  margin-bottom: 20rpx;
}

.date {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.week {
  font-size: 26rpx;
  color: #fff;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.schedule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e8e8e8;
  transition: all 0.3s ease;
}

.schedule-row:last-child {
  margin-bottom: 0;
}

.schedule-row:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #f8f9fa 0%, #f0f0f0 100%);
}

.time-badge {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  padding: 10rpx 28rpx;
  border-radius: 25rpx;
  min-width: 90rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.time-badge.morning {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.time-badge.afternoon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.slot-info {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  gap: 8rpx;
  background-color: #f5f5f5;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  margin: 0 16rpx;
}

.slot-label {
  font-size: 26rpx;
  color: #888;
}

.slot-count {
  font-size: 28rpx;
  font-weight: 600;
}

.slot-suspended {
  font-size: 26rpx;
  color: #f5576c;
  font-weight: 600;
}

.slot-btn {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  padding: 12rpx 56rpx;
  border-radius: 50rpx;
  border: none;
  transition: all 0.3s ease;
  min-width: 160rpx;
  height: 64rpx;
  line-height: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
  flex-shrink: 0;
}

.slot-btn:not(.disabled):active {
  transform: scale(0.95);
  opacity: 0.9;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.slot-btn.disabled {
  color: #999;
  background-color: #e8e8e8 !important;
  box-shadow: none;
}
