.chatroom-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.chatroom-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.header-left {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
}

.header-center {
  flex: 1;
  text-align: center;
}

.chatroom-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
}

.online-count {
  font-size: 24rpx;
  opacity: 0.8;
}

.header-right {
  width: 80rpx;
  display: flex;
  justify-content: flex-end;
}

.online-dot {
  width: 16rpx;
  height: 16rpx;
  background: #10b981;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.5);
}

.message-list {
  flex: 1;
  padding: 32rpx;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.message-content {
  margin-left: 20rpx;
  flex: 1;
}

.message-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.message-nickname {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

.message-bubble {
  background: white;
  padding: 20rpx 28rpx;
  border-radius: 0 24rpx 24rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  word-break: break-all;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: white;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.message-input {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 140rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.send-btn::after {
  border: none;
}